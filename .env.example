# Copy to .env.local for local dev, or add each variable in Vercel → Settings → Environment Variables (Production).
# Never commit .env.local. Regenerate Stripe secret key if it was ever shared.

# --- Stripe API (Live) ---
STRIPE_SECRET_KEY=sk_live_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# --- Stripe Price IDs (server) ---
